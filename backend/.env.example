# SearchV16 Backend Configuration

# Elasticsearch
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX=library

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4321,http://127.0.0.1:3000,http://127.0.0.1:4321

# Logging
LOG_LEVEL=INFO
# Configuración del Índice (Opción 3)
ELASTIC_PRIMARY_SHARDS=2
ELASTIC_REPLICAS=2

# Configuración del Nodo (Memoria JVM)
# Asumiendo 10GB de RAM por servidor, le damos la mitad (5GB) a Elasticsearch
ES_HEAP_SIZE=5g