---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión | SearchV16">
  <div class="min-h-screen flex items-center justify-center bg-radial from-base-200 to-base-300 px-4 py-12 relative overflow-hidden">
    <!-- Círculos decorativos de fondo con difuminado -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="w-full max-w-md bg-base-100 border border-base-300 rounded-3xl shadow-xl overflow-hidden backdrop-blur-md relative z-10 transition-all duration-300 hover:shadow-2xl">
      <div class="p-8 md:p-10 space-y-6">
        
        <!-- Encabezado -->
        <div class="text-center space-y-2">
          <h2 class="text-4xl font-extrabold tracking-tight font-display">
            Search <span class="bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">V16</span>
          </h2>
          <p class="text-base-content/60 text-sm">
            Ingresa al motor de búsqueda distribuido
          </p>
        </div>

        <!-- Alerta de Mensaje/Error -->
        <div id="error-alert" class="hidden alert alert-error text-xs py-3 px-4 rounded-xl border border-red-500/10 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
          <span id="error-text">Usuario o contraseña incorrectos.</span>
        </div>

        <!-- Formulario Iniciar Sesión -->
        <form id="login-form" class="space-y-5">
          <!-- Campo Usuario -->
          <div class="form-control space-y-1">
            <label class="label-text font-semibold text-xs text-base-content/70">Nombre de Usuario</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40">
                👤
              </span>
              <input
                id="username-input"
                type="text"
                required
                placeholder="ej: admin"
                autocomplete="username"
                class="input input-bordered w-full pl-11 bg-base-200 border-base-300 rounded-xl focus:bg-base-100 transition-all text-sm h-12"
              />
            </div>
          </div>

          <!-- Campo Contraseña -->
          <div class="form-control space-y-1">
            <label class="label-text font-semibold text-xs text-base-content/70">Contraseña</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40">
                🔒
              </span>
              <input
                id="password-input"
                type="password"
                required
                placeholder="••••••••"
                autocomplete="current-password"
                class="input input-bordered w-full pl-11 bg-base-200 border-base-300 rounded-xl focus:bg-base-100 transition-all text-sm h-12"
              />
            </div>
          </div>

          <!-- Botón de Envío -->
          <button
            type="submit"
            id="submit-btn"
            class="btn btn-primary w-full rounded-xl bg-gradient-to-r from-emerald-600 to-teal-500 hover:from-emerald-700 hover:to-teal-600 border-none text-white font-semibold font-display shadow-md hover:shadow-lg transition-all h-12 mt-2 cursor-pointer active:scale-98"
          >
            <span>Iniciar Sesión</span>
          </button>
        </form>

        <!-- Formulario Registro -->
        <form id="register-form" class="space-y-5 hidden">
          <!-- Campo Nombre Completo -->
          <div class="form-control space-y-1">
            <label class="label-text font-semibold text-xs text-base-content/70">Nombre Completo</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40">
                ✍️
              </span>
              <input
                id="register-fullname"
                type="text"
                placeholder="ej: Juan Pérez"
                class="input input-bordered w-full pl-11 bg-base-200 border-base-300 rounded-xl focus:bg-base-100 transition-all text-sm h-12"
              />
            </div>
          </div>

          <!-- Campo Usuario -->
          <div class="form-control space-y-1">
            <label class="label-text font-semibold text-xs text-base-content/70">Nombre de Usuario</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40">
                👤
              </span>
              <input
                id="register-username"
                type="text"
                required
                placeholder="ej: juanp"
                class="input input-bordered w-full pl-11 bg-base-200 border-base-300 rounded-xl focus:bg-base-100 transition-all text-sm h-12"
              />
            </div>
          </div>

          <!-- Campo Contraseña -->
          <div class="form-control space-y-1">
            <label class="label-text font-semibold text-xs text-base-content/70">Contraseña (Mín. 6 caracteres)</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40">
                🔒
              </span>
              <input
                id="register-password"
                type="password"
                required
                minlength="6"
                placeholder="••••••••"
                class="input input-bordered w-full pl-11 bg-base-200 border-base-300 rounded-xl focus:bg-base-100 transition-all text-sm h-12"
              />
            </div>
          </div>

          <!-- Botón de Envío Registro -->
          <button
            type="submit"
            id="register-submit-btn"
            class="btn btn-primary w-full rounded-xl bg-gradient-to-r from-emerald-600 to-teal-500 hover:from-emerald-700 hover:to-teal-600 border-none text-white font-semibold font-display shadow-md hover:shadow-lg transition-all h-12 mt-2 cursor-pointer active:scale-98"
          >
            <span>Crear Cuenta</span>
          </button>
        </form>

        <!-- Toggle de Formulario -->
        <div class="text-center pt-2">
          <button id="toggle-form-btn" class="text-xs text-emerald-600 hover:text-emerald-700 font-semibold cursor-pointer transition-colors">
            ¿No tienes cuenta? Regístrate aquí
          </button>
        </div>

        <!-- Sección de Información / Demo -->
        <div id="demo-info" class="border-t border-base-300 pt-6 text-center space-y-2">
          <p class="text-xs text-base-content/50">
            Usuario de prueba por defecto:
          </p>
          <div class="inline-flex items-center gap-1.5 bg-base-200/80 px-3 py-1.5 rounded-full border border-base-300 text-xs text-base-content/75 font-mono">
            <span>admin</span> / <span>admin123</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const API_BASE = 'http://localhost:8000';
  
  const loginForm = document.getElementById('login-form');
  const registerForm = document.getElementById('register-form');
  const toggleBtn = document.getElementById('toggle-form-btn');
  const demoInfo = document.getElementById('demo-info');

  const usernameInput = document.getElementById('username-input');
  const passwordInput = document.getElementById('password-input');
  const errorAlert = document.getElementById('error-alert');
  const errorText = document.getElementById('error-text');
  const submitBtn = document.getElementById('submit-btn');

  const headerTitle = document.querySelector('h2');
  const headerDesc = document.querySelector('p');

  let isLoginMode = true;

  // Si ya tiene sesión activa, redirigir al home directamente
  (async function() {
    try {
      const res = await fetch(`${API_BASE}/api/auth/me`, { credentials: 'include' });
      if (res.ok) {
        window.location.href = '/';
      }
    } catch (err) {
      console.warn('API no disponible para validación de sesión previa.');
    }
  })();

  // Toggle entre Iniciar Sesión y Registro
  toggleBtn.addEventListener('click', () => {
    isLoginMode = !isLoginMode;
    errorAlert.classList.add('hidden');
    
    if (isLoginMode) {
      loginForm.classList.remove('hidden');
      registerForm.classList.add('hidden');
      demoInfo.classList.remove('hidden');
      toggleBtn.textContent = '¿No tienes cuenta? Regístrate aquí';
      headerTitle.innerHTML = 'Search <span class="bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">V16</span>';
      headerDesc.textContent = 'Ingresa al motor de búsqueda distribuido';
    } else {
      loginForm.classList.add('hidden');
      registerForm.classList.remove('hidden');
      demoInfo.classList.add('hidden');
      toggleBtn.textContent = '¿Ya tienes una cuenta? Inicia sesión';
      headerTitle.innerHTML = 'Crear <span class="bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">Cuenta</span>';
      headerDesc.textContent = 'Regístrate para buscar y descargar documentos';
    }
  });

  // Manejo de Login
  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    errorAlert.classList.add('hidden');
    submitBtn.disabled = true;
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<span class="loading loading-spinner loading-sm"></span> Autenticando...';

    const username = usernameInput.value.trim();
    const password = passwordInput.value;

    try {
      const response = await fetch(`${API_BASE}/api/auth/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        credentials: 'include',
        body: JSON.stringify({ username, password })
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.detail || 'Error al iniciar sesión.');
      }

      window.location.href = '/';

    } catch (err) {
      console.error(err);
      errorText.textContent = err.message;
      errorAlert.className = 'alert alert-error text-xs py-3 px-4 rounded-xl border border-red-500/10 flex items-center gap-2';
      errorAlert.classList.remove('hidden');
      
      const card = loginForm.closest('.w-full');
      card.classList.add('animate-shake');
      setTimeout(() => card.classList.remove('animate-shake'), 500);

    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  // Manejo de Registro
  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    errorAlert.classList.add('hidden');
    
    const registerSubmitBtn = document.getElementById('register-submit-btn');
    registerSubmitBtn.disabled = true;
    const originalText = registerSubmitBtn.innerHTML;
    registerSubmitBtn.innerHTML = '<span class="loading loading-spinner loading-sm"></span> Registrando...';

    const fullname = document.getElementById('register-fullname').value.trim();
    const username = document.getElementById('register-username').value.trim();
    const password = document.getElementById('register-password').value;

    try {
      const response = await fetch(`${API_BASE}/api/auth/register`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ username, password, fullname })
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.detail || 'Error al registrar usuario.');
      }

      // Auto-login tras registro exitoso
      const loginRes = await fetch(`${API_BASE}/api/auth/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        credentials: 'include',
        body: JSON.stringify({ username, password })
      });

      if (loginRes.ok) {
        window.location.href = '/';
      } else {
        // Redirigir a login si el auto-login falla e informar
        isLoginMode = true;
        loginForm.classList.remove('hidden');
        registerForm.classList.add('hidden');
        demoInfo.classList.remove('hidden');
        toggleBtn.textContent = '¿No tienes cuenta? Regístrate aquí';
        headerTitle.innerHTML = 'Search <span class="bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent">V16</span>';
        headerDesc.textContent = 'Ingresa al motor de búsqueda distribuido';
        
        errorText.textContent = 'Registro exitoso. Por favor inicie sesión.';
        errorAlert.className = 'alert alert-success text-xs py-3 px-4 rounded-xl border border-emerald-500/10 flex items-center gap-2 text-emerald-600';
        errorAlert.classList.remove('hidden');
      }

    } catch (err) {
      console.error(err);
      errorText.textContent = err.message;
      errorAlert.className = 'alert alert-error text-xs py-3 px-4 rounded-xl border border-red-500/10 flex items-center gap-2';
      errorAlert.classList.remove('hidden');
      
      const card = registerForm.closest('.w-full');
      card.classList.add('animate-shake');
      setTimeout(() => card.classList.remove('animate-shake'), 500);
    } finally {
      registerSubmitBtn.disabled = false;
      registerSubmitBtn.innerHTML = originalText;
    }
  });
</script>

<style>
  /* Animación de entrada suave */
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .w-full {
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Animación de error (vibración) */
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-6px); }
    40%, 80% { transform: translateX(6px); }
  }
  :global(.animate-shake) {
    animation: shake 0.4s ease-in-out;
  }
</style>
