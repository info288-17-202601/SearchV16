---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div id="app" class="min-h-screen bg-base-100 text-base-content relative">
    <div
      id="landing"
      class="min-h-screen flex flex-col justify-center items-center px-4"
    >
      <div class="w-full max-w-xl text-center space-y-6 -mt-12">
        <h1
          class="text-6xl md:text-7xl font-extrabold font-display tracking-tight select-none"
        >
          Search <span
            class="bg-gradient-to-r from-emerald-600 to-teal-500 bg-clip-text text-transparent"
            >V16</span
          >
        </h1>
        <p class="text-base-content/60 text-sm max-w-sm mx-auto">
          Buscado distribuido de documentos corporativos
        </p>

        <form id="form-landing" class="relative mt-4">
          <svg
            class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-base-content/35"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            id="input-landing"
            type="text"
            placeholder="Buscar en documentos..."
            autocomplete="off"
            class="w-full pl-14 pr-28 py-4 bg-[var(--input-bg)] border border-[var(--input-border)] text-base-content rounded-full shadow-sm focus:shadow-md focus:border-[var(--input-focus-border)] focus:outline-none transition-all text-base"
          />
          <button
            type="submit"
            class="absolute right-2 top-1/2 -translate-y-1/2 px-5 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold font-display rounded-full transition-colors cursor-pointer active:scale-95"
          >
            Buscar
          </button>
        </form>
      </div>
    </div>

    <div id="results" class="hidden min-h-screen flex flex-col">
      <header
        class="sticky top-0 z-30 bg-base-100/95 backdrop-blur-md border-b border-base-300/70 px-4 md:px-8 py-3"
      >
        <div class="max-w-5xl mx-auto flex items-center gap-4">
          <a
            href="/"
            id="logo-back"
            class="flex items-center gap-1.5 cursor-pointer shrink-0"
          >
            <span class="text-lg font-bold font-display tracking-tight"
              >Search <span class="text-emerald-600">V16</span></span
            >
          </a>
          <form id="form-results" class="flex-1 max-w-lg">
            <div class="relative">
              <svg
                class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-base-content/35"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                id="input-results"
                type="text"
                placeholder="Buscar..."
                autocomplete="off"
                class="w-full pl-10 pr-4 py-2 bg-base-200 border border-transparent text-base-content rounded-full focus:bg-[var(--input-bg)] focus:border-[var(--input-focus-border)] focus:outline-none transition-all text-sm"
              />
            </div>
          </form>
        </div>
      </header>

      <main class="flex-1 max-w-5xl w-full mx-auto px-4 md:px-8 py-6">
        <div id="results-info" class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-2">
            <p id="results-summary" class="text-sm text-base-content/60"></p>
            <span
              id="offline-badge"
              class="hidden text-[10px] bg-amber-100 text-amber-800 border border-amber-200 font-semibold px-2 py-0.5 rounded-full font-display"
              >Offline Demo</span
            >
          </div>
          <span id="results-time" class="text-xs text-base-content/40 font-mono"
          ></span>
        </div>

        <div id="loading" class="hidden py-20 text-center">
          <span class="loading loading-spinner loading-lg text-emerald-600"
          ></span>
          <p class="mt-4 text-sm text-base-content/50">
            Buscando documentos...
          </p>
        </div>

        <div id="error" class="hidden py-16 text-center">
          <div
            class="w-14 h-14 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-red-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"
              ></path>
            </svg>
          </div>
          <h3 class="font-semibold text-base-content font-display">
            Error de conexión
          </h3>
          <p
            id="error-msg"
            class="text-sm text-base-content/50 mt-1 max-w-sm mx-auto"
          >
          </p>
          <div class="flex justify-center gap-2 mt-4">
            <button
              id="btn-retry"
              class="btn btn-sm btn-primary text-white rounded-full cursor-pointer"
              >Reintentar</button
            >
            <button
              id="btn-demo"
              class="btn btn-sm btn-outline rounded-full cursor-pointer"
              >Usar datos simulados</button
            >
          </div>
        </div>

        <div id="empty" class="hidden py-16 text-center">
          <div
            class="w-14 h-14 rounded-full bg-base-200 flex items-center justify-center mx-auto mb-4"
          >
            <svg
              class="w-7 h-7 text-base-content/30"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="font-semibold text-base-content font-display">
            Sin resultados
          </h3>
          <p class="text-sm text-base-content/50 mt-1">
            No se encontraron documentos para esta búsqueda.
          </p>
        </div>

        <div id="results-list" class="space-y-3"></div>

        <div
          id="pagination-controls"
          class="flex justify-center items-center gap-4 mt-8 hidden"
        >
          <button
            id="btn-prev"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-full hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition cursor-pointer"
          >
            ← Anterior
          </button>
          <span
            id="page-indicator"
            class="text-sm font-mono text-gray-600 bg-base-200 px-3 py-1 rounded-md"
          >
            Pág. 1
          </span>
          <button
            id="btn-next"
            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-full hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition cursor-pointer"
          >
            Siguiente →
          </button>
        </div>
      </main>
    </div>
  </div>
</Layout>

<script is:inline>
  // ======== CONFIG ========
  const API_BASE = "http://localhost:8000";

  // ======== DOM ========
  const $ = (id) => document.getElementById(id);
  const elLanding = $("landing");
  const elResults = $("results");
  const elFormLanding = $("form-landing");
  const elFormResults = $("form-results");
  const elInputLanding = $("input-landing");
  const elInputResults = $("input-results");
  const elResultsList = $("results-list");
  const elLoading = $("loading");
  const elError = $("error");
  const elErrorMsg = $("error-msg");
  const elEmpty = $("empty");
  const elSummary = $("results-summary");
  const elOfflineBadge = $("offline-badge");
  const elTime = $("results-time");
  const elLogoBack = $("logo-back");
  const elBtnRetry = $("btn-retry");
  const elBtnDemo = $("btn-demo");

  // Elementos DOM para Paginación
  const elPaginationControls = $("pagination-controls");
  const elBtnPrev = $("btn-prev");
  const elBtnNext = $("btn-next");
  const elPageIndicator = $("page-indicator");

  let lastQuery = "";
  let forceDemoMode = false;
  let isApiOnline = true;

  let currentPage = 1;
  const itemsPerPage = 10;

  // ======== FILE TYPE COLORS ========
  const EXT_STYLE = {
    txt: {
      bg: "bg-stone-100",
      text: "text-stone-500",
      border: "border-stone-200",
    },
    pdf: { bg: "bg-red-50", text: "text-red-500", border: "border-red-100" },
    docx: {
      bg: "bg-blue-50",
      text: "text-blue-500",
      border: "border-blue-100",
    },
    xlsx: {
      bg: "bg-emerald-50",
      text: "text-emerald-500",
      border: "border-emerald-100",
    },
  };

  function getExt(filename) {
    const ext = (filename || "").split(".").pop().toLowerCase();
    return EXT_STYLE[ext] ? ext : "txt";
  }

  // ======== HELPERS ========
  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  function formatBytes(bytes) {
    if (!bytes || bytes === 0) return "—";
    if (bytes < 1024) return bytes + " B";
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + " KB";
    return (bytes / 1048576).toFixed(1) + " MB";
  }

  function formatDate(isoStr) {
    if (!isoStr) return "";
    const d = new Date(isoStr);
    const months = [
      "Ene",
      "Feb",
      "Mar",
      "Abr",
      "May",
      "Jun",
      "Jul",
      "Ago",
      "Sep",
      "Oct",
      "Nov",
      "Dic",
    ];
    return `${d.getDate()} ${months[d.getMonth()]}, ${d.getFullYear()}`;
  }

  function escapeRegExp(string) {
    return string.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function highlightQuery(text, query) {
    if (!query || !text) return escapeHtml(text || "");
    const regex = new RegExp(`(${escapeRegExp(query)})`, "gi");
    return escapeHtml(text).replace(
      regex,
      '<mark class="px-0.5 rounded">$1</mark>',
    );
  }

  // ======== VIEWS ========
  function showLanding() {
    elResults.classList.add("hidden");
    elLanding.classList.remove("hidden");
    elInputLanding.value = "";
    elInputResults.value = "";
    elPaginationControls.classList.add("hidden"); // Ocultar paginación en landing
    window.history.pushState({}, "", "/");
  }

  function showResults(query, page = 1) {
    elLanding.classList.add("hidden");
    elResults.classList.remove("hidden");
    elInputLanding.value = query;
    elInputResults.value = query;

    // Guardamos la query y la página en la URL para mantener el historial limpio
    const pageParam = page > 1 ? `&page=${page}` : "";
    window.history.pushState(
      {},
      "",
      `/?q=${encodeURIComponent(query)}${pageParam}`,
    );
  }

  function showState(state) {
    elLoading.classList.toggle("hidden", state !== "loading");
    elError.classList.toggle("hidden", state !== "error");
    elEmpty.classList.toggle("hidden", state !== "empty");
    elResultsList.classList.toggle("hidden", state !== "results");
    if (state !== "results" && state !== "loading") {
      elSummary.textContent = "";
      elTime.textContent = "";
      elOfflineBadge.classList.add("hidden");
      elPaginationControls.classList.add("hidden"); // Ocultar si no hay un resultado válido activo
    }
  }

  // ======== API ========
  // 📃 Modificada para aceptar el parámetro opcional 'page' (por defecto 1)
  async function search(query, page = 1) {
    lastQuery = query;
    currentPage = page;

    showResults(query, page);
    showState("loading");

    const startTime = performance.now();

    try {
      // 📃 Inyectamos los query params 'query', 'page' y 'size' en la URL hacia FastAPI
      const res = await fetch(
        `${API_BASE}/search?query=${encodeURIComponent(query)}&page=${page}&size=${itemsPerPage}`,
      );

      if (!res.ok) {
        throw new Error(`Error ${res.status}: ${res.statusText}`);
      }

      const data = await res.json();
      const elapsed = ((performance.now() - startTime) / 1000).toFixed(2);

      const results = data.results || data.documents || data || [];

      if (results.length === 0) {
        showState("empty");
        elSummary.textContent = `Sin resultados para "${query}"`;
        elOfflineBadge.classList.add("hidden");
        return;
      }

      isApiOnline = true;
      renderResults(results, query);

      // 📃 Calculamos la info de paginación basada en el backend
      const totalResults = data.total || 0;
      const totalPages = Math.ceil(totalResults / itemsPerPage);

      elSummary.textContent = `${totalResults} resultado${totalResults !== 1 ? "s" : ""} para "${query}"`;
      elTime.textContent = `${elapsed}s`;
      if (data.cached) {
        elTime.textContent += " · caché";
      }
      elOfflineBadge.classList.add("hidden");
      showState("results");

      if (totalResults > itemsPerPage) {
        elPaginationControls.classList.remove("hidden");
        elPageIndicator.textContent = `Pág. ${currentPage} de ${totalPages}`;

        elBtnPrev.disabled = currentPage === 1;
        elBtnNext.disabled = currentPage >= totalPages;
      } else {
        elPaginationControls.classList.add("hidden");
      }
    } catch (err) {
      console.warn("API connection failed. Prompting for offline mode...", err);
      isApiOnline = false;
      showState("error");
      elErrorMsg.textContent =
        err.message ||
        "No se pudo establecer conexión con el servidor de búsqueda.";
    }
  }

  // ======== RENDER ========
  function renderResults(results, query) {
    elResultsList.innerHTML = "";

    results.forEach((doc) => {
      const name = doc.file_name || doc.filename || doc.title || "Documento";
      const ext = getExt(name);
      const extLabel = ext.toUpperCase();
      const style = EXT_STYLE[ext];
      const size = formatBytes(doc.file_size_bytes || doc.size);
      const date = formatDate(doc.indexed_at || doc.date);
      const score = doc.score != null ? doc.score.toFixed(3) : null;
      const snippet = doc.snippet || doc.content || "";
      const docId = doc.doc_id || doc.id || "";

      const downloadUrl =
        forceDemoMode || !isApiOnline
          ? doc.download_url || "#"
          : doc.google_drive_link ||
            `${API_BASE}/download/${encodeURIComponent(docId)}`;

      const card = document.createElement("a");
      card.href = downloadUrl;
      card.target = "_blank";
      card.rel = "noopener noreferrer";
      card.className =
        "result-card p-4 flex items-start gap-4 group block cursor-pointer";

      card.innerHTML = `
        <div class="w-10 h-10 rounded-lg ${style.bg} ${style.text} ${style.border} border flex items-center justify-center font-bold text-[10px] font-display shrink-0 mt-0.5">
          ${extLabel}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-base-content group-hover:text-emerald-600 transition-colors text-sm leading-snug font-display truncate">
            ${highlightQuery(name, query)}
          </h3>
          <div class="flex items-center gap-2 mt-1 text-xs text-base-content/45">
            <span>${size}</span>
            ${date ? `<span class="w-1 h-1 rounded-full bg-base-content/20"></span><span>${date}</span>` : ""}
            ${score !== null ? `<span class="w-1 h-1 rounded-full bg-base-content/20"></span><span class="font-mono">score: ${score}</span>` : ""}
          </div>
          ${snippet ? `<p class="text-xs text-base-content/55 mt-2 leading-relaxed line-clamp-2">${highlightQuery(snippet.substring(0, 200), query)}</p>` : ""}
        </div>
        <svg class="w-4 h-4 text-base-content/20 group-hover:text-emerald-500 transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      `;

      elResultsList.appendChild(card);
    });
  }

  // ======== EVENT LISTENERS ========
  elFormLanding.addEventListener("submit", (e) => {
    e.preventDefault();
    const q = elInputLanding.value.trim();
    if (q) search(q, 1); // 📃 Nueva búsqueda inicia siempre en Pág 1
  });

  elFormResults.addEventListener("submit", (e) => {
    e.preventDefault();
    const q = elInputResults.value.trim();
    if (q) search(q, 1); // 📃 Nueva búsqueda inicia siempre en Pág 1
  });

  // 📃 Eventos Click para Botones de Paginación
  elBtnPrev.addEventListener("click", () => {
    if (currentPage > 1) {
      search(lastQuery, currentPage - 1);
      window.scrollTo({ top: 0, behavior: "smooth" }); // Sube elegantemente al cambiar de página
    }
  });

  elBtnNext.addEventListener("click", () => {
    search(lastQuery, currentPage + 1);
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  elLogoBack.addEventListener("click", (e) => {
    e.preventDefault();
    showLanding();
  });

  elBtnRetry.addEventListener("click", () => {
    forceDemoMode = false;
    if (lastQuery) search(lastQuery, currentPage);
  });

  elBtnDemo.addEventListener("click", () => {
    forceDemoMode = true;
    if (lastQuery) search(lastQuery, currentPage);
  });

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    const page = parseInt(params.get("page") || "1", 10);
    if (q) {
      search(q, page);
    } else {
      showLanding();
    }
  });

  // ======== INIT ========
  window.addEventListener("DOMContentLoaded", () => {
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    const page = parseInt(params.get("page") || "1", 10);
    if (q) search(q, page);
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  #landing {
    animation: fadeIn 0.4s ease forwards;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
