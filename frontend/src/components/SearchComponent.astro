---
// SearchComponent.astro
// Componente reutilizable de búsqueda para SearchV16

import SearchClient from '../lib/searchClient';

interface Props {
  placeholder?: string;
  maxResults?: number;
  minChars?: number;
}

const { 
  placeholder = 'Buscar documentos...',
  maxResults = 20,
  minChars = 2
} = Astro.props;
---

<div class="search-component">
  <div class="search-box">
    <input 
      type="text" 
      placeholder={placeholder}
      class="search-input"
      id="searchInput"
      data-min-chars={minChars}
      data-max-results={maxResults}
    />
    <button class="search-button" id="searchBtn" aria-label="Buscar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
    </button>
  </div>

  <div class="results-container" id="resultsContainer" hidden>
    <div class="results-header">
      <span class="result-count" id="resultCount"></span>
      <span class="result-time" id="resultTime"></span>
    </div>
    
    <div class="results-list" id="resultsList"></div>
  </div>

  <div class="loading" id="loading" hidden>
    <div class="spinner"></div>
    <span>Buscando...</span>
  </div>

  <div class="error-message" id="errorMessage" hidden></div>
</div>

<script define:vars={{ maxResults, minChars }}>
  import SearchClient from '../lib/searchClient';

  const client = new SearchClient('http://localhost:8000');
  
  const searchInput = document.getElementById('searchInput');
  const searchBtn = document.getElementById('searchBtn');
  const resultsContainer = document.getElementById('resultsContainer');
  const resultsList = document.getElementById('resultsList');
  const resultCount = document.getElementById('resultCount');
  const resultTime = document.getElementById('resultTime');
  const loading = document.getElementById('loading');
  const errorMessage = document.getElementById('errorMessage');

  let searchTimeout;

  async function performSearch() {
    const query = searchInput.value.trim();

    if (query.length < minChars) {
      resultsContainer.hidden = true;
      errorMessage.hidden = true;
      return;
    }

    loading.hidden = false;
    resultsContainer.hidden = true;
    errorMessage.hidden = true;

    try {
      const response = await client.search(query, maxResults);
      
      displayResults(response.results, response.total, response.took_ms);
      resultCount.textContent = `${response.count} de ${response.total} resultados`;
      resultTime.textContent = `(${response.took_ms}ms)`;
      
      resultsContainer.hidden = false;
    } catch (error) {
      showError('Error al buscar. Por favor, intenta de nuevo.');
      console.error(error);
    } finally {
      loading.hidden = true;
    }
  }

  function displayResults(results, total, timeMs) {
    resultsList.innerHTML = '';

    if (results.length === 0) {
      resultsList.innerHTML = '<p class="no-results">No se encontraron resultados</p>';
      return;
    }

    results.forEach((result) => {
      const resultEl = document.createElement('div');
      resultEl.className = 'result-item';

      let highlightHtml = '';
      if (result.highlight?.content) {
        highlightHtml = `
          <div class="highlight">
            <strong>Coincidencias:</strong>
            <p>${result.highlight.content[0]}</p>
          </div>
        `;
      }

      let downloadBtn = '';
      if (result.google_drive_link) {
        downloadBtn = `
          <div class="result-actions">
            <a href="${result.google_drive_link}" target="_blank" rel="noopener noreferrer" class="download-btn" title="Descargar en Google Drive">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Descargar
            </a>
          </div>
        `;
      }

      resultEl.innerHTML = `
        <h3 class="result-title">${escapeHtml(result.title)}</h3>
        <p class="result-excerpt">${escapeHtml(result.content.substring(0, 150))}...</p>
        ${highlightHtml}
        <div class="result-metadata">
          <small class="result-score">Score: ${result.score.toFixed(2)}</small>
          ${result.source.author ? `<small class="result-author">Autor: ${escapeHtml(result.source.author)}</small>` : ''}
          ${result.source.year ? `<small class="result-year">Año: ${result.source.year}</small>` : ''}
        </div>
        ${downloadBtn}
      `;

      resultsList.appendChild(resultEl);
    });
  }

  function showError(message) {
    errorMessage.textContent = message;
    errorMessage.hidden = false;
    resultsContainer.hidden = true;
  }

  function escapeHtml(text) {
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    };
    return text.replace(/[&<>"']/g, m => map[m]);
  }

  // Event listeners
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(performSearch, 300);
  });

  searchBtn.addEventListener('click', performSearch);

  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      clearTimeout(searchTimeout);
      performSearch();
    }
  });
</script>

<style>
  .search-component {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
  }

  .search-box {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .search-input {
    flex: 1;
    padding: 12px 16px;
    font-size: 16px;
    background-color: var(--input-bg);
    border: 2px solid var(--input-border);
    color: var(--color-base-content);
    border-radius: 8px;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--input-focus-border);
    box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.1);
  }

  .search-button {
    padding: 12px 16px;
    background: var(--color-primary);
    color: var(--color-primary-content);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-button:hover {
    opacity: 0.9;
  }

  .search-button:active {
    opacity: 0.8;
  }

  .results-container {
    background: var(--card-bg);
    border-radius: 8px;
    border: 1px solid var(--card-border);
    overflow: hidden;
  }

  .results-header {
    padding: 12px 16px;
    background: var(--color-base-200);
    border-bottom: 1px solid var(--card-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    color: var(--color-base-content);
    opacity: 0.8;
  }

  .result-count {
    font-weight: 500;
  }

  .result-time {
    opacity: 0.6;
  }

  .results-list {
    display: flex;
    flex-direction: column;
    max-height: 600px;
    overflow-y: auto;
  }

  .result-item {
    padding: 16px;
    border-bottom: 1px solid var(--card-border);
    transition: background-color 0.2s;
    background: var(--card-bg);
    color: var(--color-base-content);
  }

  .result-item:last-child {
    border-bottom: none;
  }

  .result-item:hover {
    background-color: var(--color-base-200);
  }

  .result-title {
    margin: 0 0 8px 0;
    font-size: 18px;
    color: var(--color-primary);
    font-weight: 600;
  }

  .result-title:hover {
    text-decoration: underline;
  }

  .result-excerpt {
    margin: 8px 0;
    color: var(--color-base-content);
    opacity: 0.8;
    line-height: 1.5;
    font-size: 14px;
  }

  .highlight {
    background: var(--color-base-200);
    border-left: 4px solid var(--color-primary);
    padding: 10px 12px;
    margin: 10px 0;
    border-radius: 4px;
    font-size: 13px;
    color: var(--color-base-content);
  }

  .highlight strong {
    display: block;
    color: var(--color-primary);
    margin-bottom: 4px;
  }

  .highlight p {
    margin: 0;
    color: var(--color-base-content);
  }

  :global(.highlight mark) {
    background: #ffeb3b;
    color: #000000;
    padding: 2px 4px;
    font-weight: 600;
  }

  [data-theme="nordic-dark"] :global(.highlight mark) {
    background: rgba(16, 185, 129, 0.3) !important;
    color: #34d399 !important;
  }

  [data-theme="nordic-contrast"] :global(.highlight mark) {
    background: #ffff00 !important;
    color: #000000 !important;
  }

  .result-metadata {
    display: flex;
    gap: 16px;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .result-metadata small {
    color: var(--color-base-content);
    opacity: 0.6;
    font-size: 12px;
  }

  .result-score {
    color: var(--color-primary);
    font-weight: 500;
  }

  .result-actions {
    margin-top: 12px;
    display: flex;
    gap: 8px;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-success);
    color: var(--color-success-content, #ffffff);
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .download-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  [data-theme="nordic-contrast"] .download-btn {
    background: #00ff00 !important;
    color: #000000 !important;
    border: 2px solid #00ff00;
  }
  [data-theme="nordic-contrast"] .download-btn:hover {
    background: #000000 !important;
    color: #00ff00 !important;
  }

  .download-btn:active {
    transform: translateY(0);
  }

  .no-results {
    padding: 24px;
    text-align: center;
    color: var(--color-base-content);
    opacity: 0.6;
    font-size: 16px;
  }

  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px;
    color: var(--color-base-content);
    opacity: 0.8;
  }

  .spinner {
    width: 20px;
    height: 20px;
    border: 3px solid var(--color-base-200);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .error-message {
    padding: 12px 16px;
    background: var(--color-error);
    color: var(--color-error-content, #ffffff);
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 16px;
  }

  @media (max-width: 640px) {
    .search-box {
      flex-direction: column;
    }

    .search-button {
      width: 100%;
    }

    .results-list {
      max-height: 400px;
    }

    .result-metadata {
      gap: 8px;
    }
  }
</style>
