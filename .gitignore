# ==========================================
# Archivos de Sistema y Entorno
# ==========================================
.DS_Store
Thumbs.db
*.log



# ==========================================
# Backend (Python / FastAPI)
# ==========================================
# Entorno virtual
backend/venv/
backend/.venv/
backend/env/

# Caché de Python
backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.pytest_cache/

# Configuración y Credenciales Sensibles
backend/.env
backend/credentials.json
backend/token.json

# Logs locales de la app
backend/pipeline_ingesta.log

# Documentos locales de prueba (Ingesta)
backend/Documentos/

# ==========================================
# Frontend (Astro / Node)
# ==========================================
# Dependencias
frontend/node_modules/

# Caché de Astro y TypeScript
frontend/.astro/
frontend/.cache/

# Carpeta de build / distribución
frontend/dist/

# Logs de npm
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*